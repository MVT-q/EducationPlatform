<UserControl x:Class="Education_Platform.Views.Profile.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Education_Platform.Views.Profile"
             xmlns:vm="clr-namespace:Education_Platform.ViewModels.Profile"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:ProfileViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0"
                             Padding="25"
                             Margin="0 0 20 0">
                <StackPanel>
                    <TextBlock Text="Profile"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0 0 0 25"/>

                    <Border Width="140"
                            Height="140"
                            CornerRadius="70"
                            HorizontalAlignment="Center"
                            ClipToBounds="True"
                            Margin="0 0 0 20">

                        <Image Source="{Binding AvatarPath}"
                               Stretch="Uniform"/>

                    </Border>

                    <TextBlock Text="{Binding Login}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding Role}"
                               FontSize="15"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               Margin="0 5 0 25"/>

                    <Button Content="Choose Avatar"
                            Height="40"
                            Command="{Binding ChooseAvatarCommand}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1"
                                 Padding="30">
                <StackPanel>
                    <TextBlock Text="Account Information"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0 0 0 25"/>

                    <TextBlock Text="Current login"
                               FontWeight="SemiBold"
                               Margin="0 0 0 5"/>

                    <TextBlock Text="{Binding Login}"
                               FontSize="16"
                               Margin="0 0 0 20"/>

                    <TextBlock Text="Email"
                               FontWeight="SemiBold"
                               Margin="0 0 0 5"/>

                    <TextBlock Text="{Binding Email}"
                               FontSize="16"
                               Margin="0 0 0 20"/>

                    <TextBlock Text="Role"
                               FontWeight="SemiBold"
                               Margin="0 0 0 5"/>

                    <TextBlock Text="{Binding Role}"
                               FontSize="16"
                               Margin="0 0 0 30"/>

                    <Separator Margin="0 0 0 25"/>

                    <TextBlock Text="Change login"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0 0 0 15"/>

                    <TextBox Text="{Binding NewLogin}"
                             Width="300"
                             Margin="0 0 0 20"
                             FontSize="14"
                             materialDesign:HintAssist.Hint="New login"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                    <Button Content="Update Login"
                            Width="180"
                            Height="40"
                            Command="{Binding ChangeLoginCommand}"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
