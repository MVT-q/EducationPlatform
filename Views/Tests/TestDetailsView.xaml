<UserControl x:Class="Education_Platform.Views.Tests.TestDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Education_Platform.Views.Tests"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="20">
            <materialDesign:Card Padding="20"
                                 Margin="0 0 0 20">
                <StackPanel>
                    
                    <TextBlock Text="{Binding Title}"
                               FontSize="24"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding Description}"
                               Margin="0 10 0 20"
                               FontSize="14"
                               TextWrapping="Wrap"/>

                    <TextBlock Margin="0 0 0 10">
                        <Run Text="Questions: "
                             FontWeight="SemiBold"/>
                        <Run Text="{Binding QuestionsCount, Mode=OneWay}"/>
                    </TextBlock>

                    <TextBlock FontSize="14"
                               Margin="0 0 0 10">
                        <Run Text="Attempts: "
                             FontWeight="SemiBold"/>
                        <Run Text="{Binding AttemptsText}"/>
                    </TextBlock>

                    <TextBlock Text="No attempts left"
                               Foreground="Red"
                               FontWeight="Bold"
                               Margin="0 0 0 10"
                               Visibility="{Binding HasNoAttempts,
                                            Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="Start Test"
                            Width="400"
                            Height="40"
                            FontSize="20"                           
                            Command="{Binding StartTestCommand}"
                            IsEnabled="{Binding CanStartTest}" 
                            Cursor="Hand"
                            Visibility="{Binding IsStudent,
                                         Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
                
            </materialDesign:Card>
            
            <TextBlock Text="Questions"
                       FontSize="25"
                       FontWeight="Bold"
                       Margin="0 10 0 15"/>

            <ItemsControl ItemsSource="{Binding Questions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E5E7EB"
                                Background="#FAFAFA"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0 0 0 10">

                            <StackPanel>

                                <TextBlock Text="{Binding Text}"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding Type}"
                                           Foreground="Gray"
                                           FontSize="12"/>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
