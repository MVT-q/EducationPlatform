<UserControl x:Class="Education_Platform.Views.Tests.TestPassingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Education_Platform.Views.Tests"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <ItemsControl ItemsSource="{Binding Questions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0 0 0 20"
                                             Padding="20">
                            <StackPanel>
                                <TextBlock FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="Blue"
                                           Margin="0 0 0 8"
                                           Text="{Binding Number,
                                                          StringFormat=Question {0}}"/>
                                <TextBlock Text="{Binding Text}"
                                           FontWeight="Bold"
                                           Margin="0 0 0 10"/>

                                <ItemsControl ItemsSource="{Binding Answers}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            
                                            <Setter Property="Visibility" 
                                                    Value="Collapsed"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" 
                                                             Value="Single choice">
                                                    
                                                    <Setter Property="Visibility" 
                                                            Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton Content="{Binding Text}"
                                                         IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding Answers}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" 
                                                    Value="Collapsed"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" 
                                                             Value="Multiple choice">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Text}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBox Text="{Binding TextAnswer}"
                                         Margin="0 10 0 0">

                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" 
                                                    Value="Collapsed"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" 
                                                             Value="Text">
                                                    <Setter Property="Visibility" 
                                                            Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>

                                </TextBox>

                            </StackPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <Button Content="Submit"
                    Width="220"
                    Height="45"
                    HorizontalAlignment="Left"
                    Command="{Binding SubmitCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
