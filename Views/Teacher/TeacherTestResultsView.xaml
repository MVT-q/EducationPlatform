<UserControl x:Class="Education_Platform.Views.Teacher.TeacherTestResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Education_Platform.Views.Teacher"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0 0 0 20">
            <TextBlock Text="{Binding TestTitle}"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal"
                    Margin="0 50 0 20">

            <materialDesign:Card Width="180"
                                 Padding="15"
                                 Margin="0 0 15 0">
                <StackPanel>
                    <TextBlock Text="Average Score"
                               FontSize="14"
                               Opacity="0.7"/>

                    <TextBlock Text="{Binding Average,
                                  StringFormat={}{0:F1}}"
                               FontSize="28"
                               FontWeight="Bold"/>
                </StackPanel>

            </materialDesign:Card>

            <materialDesign:Card Width="180"
                                 Padding="15">
                <StackPanel>
                    <TextBlock Text="Students passed"
                               FontSize="14"/>

                    <TextBlock Text="{Binding StudentsCount}"
                               FontSize="28"
                               FontWeight="Bold"/>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Attempts}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="False">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="User"
                                    Width="400"
                                    FontSize="16"
                                    Binding="{Binding User.Login}"/>

                <DataGridTextColumn Header="Score"
                                    Width="120"
                                    FontSize="16"
                                    Binding="{Binding Score, StringFormat={}{0:F1}}"/>

                <DataGridTextColumn Header="%"
                                    Width="120"
                                    FontSize="16"
                                    Binding="{Binding Percentage, StringFormat={}{0:F1}%}"/>

                <DataGridTextColumn Header="Date"
                                    Width="220"
                                    FontSize="16"
                                    Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"/>

                <DataGridTemplateColumn Header="Details"
                                        Width="120">

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>

                            <Button Content="Open"
                                    Command="{Binding DataContext.OpenAttemptDetailsCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding Id}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Width="80"/>

                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
