<UserControl x:Class="Education_Platform.Views.Results.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Education_Platform.Views.Results"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <ScrollViewer>
        <StackPanel>
            <StackPanel>
                <TextBlock Text="My Results"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="20 20 20 10"/>
            </StackPanel>

            <TextBlock Text="No completed tests yet"
                       FontSize="18"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       Margin="20">

                <TextBlock.Style>
                    <Style TargetType="TextBlock">

                        <Setter Property="Visibility"
                                Value="Collapsed"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding Attempts.Count}"
                                         Value="0">

                                <Setter Property="Visibility"
                                        Value="Visible"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>
                </TextBlock.Style>

            </TextBlock>

            <ItemsControl ItemsSource="{Binding Attempts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="10"
                                             Padding="20">
                            <StackPanel>
                                <TextBlock Text="{Binding Test.Title}"
                                           FontSize="16"
                                           FontWeight="Bold"/>

                                <TextBlock FontSize="15"
                                           Margin="0 10 0 0">
                                    <Run Text="Score: "
                                         FontWeight="SemiBold"/>
                                    <Run Text="{Binding Score, StringFormat={}{0:F1}}"/>
                                </TextBlock>

                                <TextBlock FontSize="15">
                                    <Run Text="Percentage: "
                                         FontWeight="SemiBold"/>
                                    <Run Text="{Binding Percentage, Mode=OneWay, StringFormat={}{0:F1}}"/>
                                    <Run Text="%"/>
                                </TextBlock>

                                <TextBlock Margin="0 6 0 0"
                                           Foreground="Gray"
                                           FontSize="12">

                                    <Run Text="Completed: "/>

                                    <Run Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"/>

                                </TextBlock>

                                <Button Content="Details"
                                        Width="120"
                                        Margin="0 15 0 0"
                                        HorizontalAlignment="Left"
                                        Command="{Binding DataContext.OpenDetailsCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
