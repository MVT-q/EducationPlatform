<Window x:Class="Education_Platform.Views.Windows.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Education_Platform.ViewModels.Windows"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="AuthWindow" Height="650" Width="800"
        Style="{StaticResource MaterialDesignWindow}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Cursor="">

    <Window.DataContext>
        <vm:AuthViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Background="#F3F4F6">
        <Border Background="White"
                CornerRadius="20"
                Padding="35"
                MaxWidth="450"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Education Platform" 
                           FontSize="28" 
                           Margin="0 0 0 20"/>

                <TextBox Text="{Binding Login,
                                UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 0 0 4"
                         materialDesign:HintAssist.Hint="Login"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                <TextBlock Text="4-16 chars, letters, numbers and _ only"
                           FontSize="11"
                           Foreground="Gray"
                           Margin="2 0 0 4"
                           Visibility="{Binding IsRegisterMode,
                                        Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <TextBlock Text="{Binding LoginError}"
                           Foreground="Red"
                           FontSize="12"
                           Margin="0 0 0 12"/>

                <Grid Margin="0 0 0 10">

                    <PasswordBox x:Name="PasswordBox"
                                 Width="400"
                                 Margin="0 0 0 4"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                 materialDesign:HintAssist.Hint="Password"/>

                    <TextBox x:Name="PasswordVisibleBox"
                             Margin="0 0 0 4"
                             Width="400"
                             Visibility="Collapsed"
                             Text="{Binding Password,
                                    UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.Hint="Password"/>

                    <Button Width="47"
                            Height="25"
                            HorizontalAlignment="Right"
                            Click="TogglePassword_Click"
                            Style="{StaticResource MaterialDesignToolButton}">
                        <materialDesign:PackIcon Kind="Eye"/>
                    </Button>

                </Grid>

                <TextBlock Text="6-16 chars, upper/lower case, digit and special char"
                           FontSize="11"
                           Foreground="Gray"
                           Margin="2 0 0 4"
                           Visibility="{Binding IsRegisterMode,
                                        Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <TextBlock Text="{Binding PasswordError}"
                           Foreground="Red"
                           Margin="0 0 0 12"
                           FontSize="12"/>

                <Grid Margin="0 0 0 10"
                      Visibility="{Binding IsRegisterMode,
                                   Converter={StaticResource BooleanToVisibilityConverter}}">

                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Margin="0 0 0 4"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                                 Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                 materialDesign:HintAssist.Hint="Confirm password"/>

                    <TextBox x:Name="ConfirmPasswordVisibleBox"
                             Margin="0 0 0 4"
                             Visibility="Collapsed"
                             Text="{Binding ConfirmPassword,
                                    UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.Hint="Confirm password"/>

                    <Button Width="47"
                            Height="25"
                            HorizontalAlignment="Right"
                            Click="ToggleConfirmPassword_Click"
                            Style="{StaticResource MaterialDesignToolButton}">
                        <materialDesign:PackIcon Kind="Eye"/>
                    </Button>

                </Grid>

                <TextBlock Text="{Binding ConfirmPasswordError}"
                           Foreground="Red"
                           FontSize="12"
                           Margin="0 0 0 12"
                           Visibility="{Binding IsRegisterMode,
                                        Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <TextBox x:Name="EmailTextBox"
                         Margin="0 0 0 4"
                         Height="35"
                         Text="{Binding Email}"
                         Visibility="{Binding IsRegisterMode,
                                      Converter={StaticResource BooleanToVisibilityConverter}}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         materialDesign:HintAssist.Hint="Email"/>

                <TextBlock Text="{Binding EmailError}"
                           Foreground="Red"
                           FontSize="12"
                           Margin="0 0 0 12"
                           Visibility="{Binding IsRegisterMode,
                                        Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Button Height="35"
                        Margin="0 15"
                        Command="{Binding SubmitCommand}"
                        FontSize="15"
                        FontWeight="SemiBold">

                    <Button.Style>
                        <Style TargetType="Button"
                               BasedOn="{StaticResource MaterialDesignRaisedButton}">

                            <Setter Property="Content" 
                                    Value="Sign In"/>

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsRegisterMode}" 
                                             Value="True">
                                    <Setter Property="Content" 
                                            Value="Sign Up"/>
                                </DataTrigger>

                            </Style.Triggers>

                        </Style>
                    </Button.Style>

                </Button>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <StackPanel.Style>
                        <Style TargetType="StackPanel">

                            <Setter Property="Tag" Value="Don't have an account?"/>

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsRegisterMode}" Value="True">
                                    <Setter Property="Tag" Value="Already have an account?"/>
                                </DataTrigger>

                            </Style.Triggers>

                        </Style>
                    </StackPanel.Style>

                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=Tag}"/>

                    <Button Margin="6 0 0 0"
                            Padding="4"
                            BorderThickness="0"
                            Background="Transparent"
                            Foreground="#3F51B5">

                        <Button.Style>
                            <Style TargetType="Button">

                                <Setter Property="Content" Value="Sign Up"/>
                                <Setter Property="Command"
                                        Value="{Binding SwitchToRegisterCommand}"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsRegisterMode}" Value="True">

                                        <Setter Property="Content" Value="Sign In"/>
                                        <Setter Property="Command"
                                                Value="{Binding SwitchToLoginCommand}"/>

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>
